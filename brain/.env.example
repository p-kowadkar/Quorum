# Brain environment.
# The mock (mock_app.py) needs NONE of these — they are for the real brain (app.py).

# OpenRouter — the only key the brain ever needs.
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: HTTP attribution headers OpenRouter shows on your dashboard.
OPENROUTER_HTTP_REFERER=https://github.com/p-kowadkar/Quorum
OPENROUTER_X_TITLE=Quorum

# Optional: server port (defaults to 8000).
PORT=8000
