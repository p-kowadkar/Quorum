# Quorum — Discord voice-call channel.
# Copy to .env and fill in. NEVER commit .env (gitignored). REGENERATE any token that has ever been pasted anywhere.

# --- Discord ---
DISCORD_GUILD_ID=
DISCORD_TEXT_CHANNEL_ID=
DISCORD_VOICE_CHANNEL_ID=
# One bot token per agent (Discord Developer Portal → each app → Bot → Reset Token)
DISCORD_ORCHESTRATOR_TOKEN=
DISCORD_ROOTCAUSE_TOKEN=
DISCORD_CODER_TOKEN=
DISCORD_CRITIC_TOKEN=
DISCORD_PM_TOKEN=
# Comma-separated NUMERIC Discord user IDs allowed to approve (enable Developer Mode → right-click user → Copy User ID). NOT usernames.
DISCORD_APPROVER_USER_IDS=

# --- Brain (the same FastAPI service Telegram uses) ---
BRAIN_URL=https://your-tunnel.ngrok-free.dev
BRAIN_WEBHOOK_SECRET=

# --- ElevenLabs ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
EL_VOICE_ORCH=
EL_VOICE_ROOT=
EL_VOICE_CODER=
EL_VOICE_CRITIC=
EL_VOICE_PM=

# --- Service ---
PORT=8080
SESSION_ID=inc_001
